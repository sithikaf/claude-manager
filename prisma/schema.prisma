generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Account {
    id          String      @id @default(cuid())
    name        String
    dirPath     String      @unique
    displayName String?
    email       String?
    agents      Agent[]
    skills      Skill[]
    commands    Command[]
    plugins     Plugin[]
    mcpServers  McpServer[]
}

model Project {
    id       String    @id @default(cuid())
    name     String
    dirPath  String    @unique
    commands Command[]
}

model Agent {
    id          String  @id @default(cuid())
    name        String
    description String?
    tools       String?
    model       String?
    color       String?
    filePath    String  @unique
    content     String
    source      String  @default("account")
    accountId   String
    account     Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
    pluginId    String?
    plugin      Plugin? @relation(fields: [pluginId], references: [id], onDelete: Cascade)
}

model Skill {
    id          String  @id @default(cuid())
    name        String
    description String?
    author      String?
    version     String?
    dirPath     String  @unique
    content     String
    source      String  @default("account")
    hasExamples Boolean @default(false)
    hasScripts  Boolean @default(false)
    accountId   String
    account     Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
    pluginId    String?
    plugin      Plugin? @relation(fields: [pluginId], references: [id], onDelete: Cascade)
}

model Command {
    id          String   @id @default(cuid())
    name        String
    description String?
    filePath    String   @unique
    content     String
    source      String   @default("account")
    accountId   String?
    account     Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)
    projectId   String?
    project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
    pluginId    String?
    plugin      Plugin?  @relation(fields: [pluginId], references: [id], onDelete: Cascade)
}

model Plugin {
    id          String      @id @default(cuid())
    name        String
    description String?
    author      String?
    category    String?
    dirPath     String      @unique
    accountId   String
    account     Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
    agents      Agent[]
    skills      Skill[]
    commands    Command[]
    mcpServers  McpServer[]
}

model McpServer {
    id       String  @id @default(cuid())
    name     String
    type     String  @default("stdio")
    command  String?
    args     String?
    url      String?
    envVars  String?
    scope    String  @default("account")
    filePath String
    config   String

    accountId String
    account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
    pluginId  String?
    plugin    Plugin? @relation(fields: [pluginId], references: [id], onDelete: Cascade)
}

model ScanStatus {
    id        String   @id @default("singleton")
    lastScan  DateTime @default(now())
    itemCount Int      @default(0)
}

model MarketplaceItem {
    id             String   @id @default(cuid())
    externalId     String
    category       String
    source         String
    name           String
    description    String?
    author         String?
    version        String?
    tags           String?
    repositoryUrl  String?
    homepage       String?
    downloadCount  Int?
    stars          Int?
    transportType  String?
    packageName    String?
    installCommand String?
    installConfig  String?
    rawData        String?
    fetchedAt      DateTime @default(now())

    @@unique([source, externalId])
    @@index([category])
}

model MarketplaceSyncStatus {
    id        String   @id
    lastSync  DateTime @default(now())
    itemCount Int      @default(0)
    status    String   @default("idle")
    error     String?
}
